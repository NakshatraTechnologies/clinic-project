# ===========================================================
# Clinic Project — Root Environment Variables Template
# ===========================================================
# This file shows ALL environment variables needed for
# the entire project (Backend + Frontend + Docker).
#
# For deployment, create TWO env files on your server:
#   .env.production   — Used by docker-compose.prod.yml
#   .env.staging      — Used by docker-compose.staging.yml
#
# For local development, copy relevant variables into:
#   Backend/.env        — Backend local dev
#   Frontend/.env.local — Frontend local dev
# ===========================================================

# ─── Server Configuration ───
PORT=5000
NODE_ENV=development
# Options: development | staging | production

# ─── MongoDB Atlas Connection ───
MONGO_URI=mongodb+srv://YOUR_DB_USER:YOUR_DB_PASSWORD@cluster0.xxxxx.mongodb.net/YOUR_DB_NAME?retryWrites=true&w=majority
# Replace YOUR_DB_USER, YOUR_DB_PASSWORD, and YOUR_DB_NAME
# Typical DB names: Clinic (production), clinic_test (staging), clinic_dev (local)

# ─── JWT Authentication ───
JWT_SECRET=your_jwt_secret_key_change_this
# Generate a strong secret: openssl rand -hex 32
JWT_EXPIRE=30d

# ─── CORS / Frontend URL ───
FRONTEND_URL=http://localhost:5173
# Production: https://clinic.yourdomain.com
# Multiple origins (comma-separated): https://clinic.yourdomain.com,https://staging.clinic.yourdomain.com

# ─── Frontend (Vite - Build-time only) ───
VITE_API_BASE=http://localhost:5000/api
# Production: https://api.clinic.yourdomain.com/api
# Staging:    https://staging-api.clinic.yourdomain.com/api
# Note: This is passed as a Docker build arg, not runtime env
